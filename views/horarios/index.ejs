<%- include('../components/header.ejs') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Horarios</h1>
            <p class="text-muted mb-0">
                <% if (isAdmin) { %>
                    Administra horarios y revisa disponibilidad por fecha.
                <% } else { %>
                    Consulta los horarios disponibles para reservar por fecha.
                <% } %>
            </p>
        </div>
        <% if (isAdmin) { %>
            <a href="/horarios/nuevo" class="btn btn-primary">Nuevo horario</a>
        <% } %>
    </div>

    <%- include('../components/error-panel.ejs') %>

    <% if (typeof(success) !== "undefined" && success) { %>
        <div class="alert alert-success" role="alert">
            <%= success %>
        </div>
    <% } %>

    <div class="card mb-4">
        <div class="card-body">
            <form action="/horarios" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label" for="fecha">Fecha</label>
                    <input class="form-control" type="date" name="fecha" id="fecha" value="<%= filters.fecha %>" required>
                </div>
                <div class="col-md-5">
                    <label class="form-label" for="cancha_id">Cancha</label>
                    <select class="form-select" name="cancha_id" id="cancha_id">
                        <option value="">Todas</option>
                        <% canchas.forEach((cancha) => { %>
                            <option value="<%= cancha.id %>" <%= Number(filters.cancha_id) === cancha.id ? 'selected' : '' %>>
                                <%= cancha.nombre %> - <%= cancha.tipoCancha ? cancha.tipoCancha.nombre : 'Sin tipo' %>
                            </option>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-outline-primary w-100">Buscar disponibilidad</button>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <% if (!horarios.length) { %>
                <div class="p-4 text-center text-muted">
                    No hay horarios
                    <% if (!isAdmin) { %>
                        disponibles
                    <% } %>
                    para la fecha seleccionada.
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Cancha</th>
                                <th>Tipo</th>
                                <th>Fecha</th>
                                <th>Hora inicio</th>
                                <th>Hora fin</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% horarios.forEach((horario) => { %>
                                <tr>
                                    <td><%= horario.cancha.nombre %></td>
                                    <td><%= horario.cancha.tipoCancha ? horario.cancha.tipoCancha.nombre : 'Sin tipo' %></td>
                                    <td><%= horario.fecha %></td>
                                    <td><%= horario.hora_inicio.slice(0, 5) %></td>
                                    <td><%= horario.hora_fin.slice(0, 5) %></td>
                                    <td>
                                        <% if (horario.disponible) { %>
                                            <span class="badge text-bg-success">Disponible</span>
                                        <% } else { %>
                                            <span class="badge text-bg-secondary">No disponible</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <% if (isAdmin) { %>
                                            <form action="/horarios/<%= horario.id %>/eliminar" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                            </form>
                                        <% } else if (horario.disponible) { %>
                                            <form action="/reservas" method="post" class="d-inline">
                                                <input type="hidden" name="horario_id" value="<%= horario.id %>">
                                                <button type="submit" class="btn btn-sm btn-primary">Reservar</button>
                                            </form>
                                        <% } else { %>
                                            <span class="text-muted small">No disponible</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../components/footer.ejs') %>
