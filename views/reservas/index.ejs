<%- include('../components/header.ejs') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Reservas</h1>
            <p class="text-muted mb-0">
                <% if (isAdmin) { %>
                    Administra todas las reservas del sistema.
                <% } else { %>
                    Consulta tu historial y gestiona tus reservas.
                <% } %>
            </p>
        </div>
        <a href="/horarios" class="btn btn-outline-primary">Ver horarios</a>
    </div>

    <%- include('../components/error-panel.ejs') %>

    <% if (typeof(success) !== "undefined" && success) { %>
        <div class="alert alert-success" role="alert">
            <%= success %>
        </div>
    <% } %>

    <div class="card">
        <div class="card-body p-0">
            <% if (!reservas.length) { %>
                <div class="p-4 text-center text-muted">
                    No hay reservas registradas.
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <% if (isAdmin) { %>
                                    <th>Cliente</th>
                                <% } %>
                                <th>Cancha</th>
                                <th>Tipo</th>
                                <th>Fecha</th>
                                <th>Horario</th>
                                <th>Estado</th>
                                <th class="text-end">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reservas.forEach((reserva) => { %>
                                <tr>
                                    <% if (isAdmin) { %>
                                        <td><%= reserva.usuario.nombre %> (<%= reserva.usuario.email %>)</td>
                                    <% } %>
                                    <td><%= reserva.horario.cancha.nombre %></td>
                                    <td><%= reserva.horario.cancha.tipoCancha ? reserva.horario.cancha.tipoCancha.nombre : 'Sin tipo' %></td>
                                    <td><%= reserva.horario.fecha %></td>
                                    <td>
                                        <%= reserva.horario.hora_inicio.slice(0, 5) %> -
                                        <%= reserva.horario.hora_fin.slice(0, 5) %>
                                    </td>
                                    <td>
                                        <% if (reserva.estado === 'confirmada') { %>
                                            <span class="badge text-bg-success">Confirmada</span>
                                        <% } else { %>
                                            <span class="badge text-bg-secondary">Cancelada</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <% if (!isAdmin) { %>
                                            <% if (reserva.estado === 'confirmada') { %>
                                                <form action="/reservas/<%= reserva.id %>/cancelar" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Cancelar</button>
                                                </form>
                                                <% if (reviewableReservationIds.includes(reserva.id)) { %>
                                                    <a href="/resenas/nueva/<%= reserva.horario.cancha.id %>" class="btn btn-sm btn-outline-primary">Reseñar</a>
                                                <% } %>
                                            <% } else { %>
                                                <span class="text-muted small">Sin acciones</span>
                                            <% } %>
                                        <% } else { %>
                                            <form action="/reservas/<%= reserva.id %>/estado" method="post" class="d-inline-flex gap-2 justify-content-end">
                                                <select class="form-select form-select-sm" name="estado">
                                                    <option value="confirmada" <%= reserva.estado === 'confirmada' ? 'selected' : '' %>>Confirmada</option>
                                                    <option value="cancelada" <%= reserva.estado === 'cancelada' ? 'selected' : '' %>>Cancelada</option>
                                                </select>
                                                <button type="submit" class="btn btn-sm btn-outline-primary">Guardar</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../components/footer.ejs') %>
