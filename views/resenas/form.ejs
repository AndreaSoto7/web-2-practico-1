<%- include('../components/header.ejs') %>

<div class="container py-4">
    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h1 class="card-title mb-1">Nueva reseña</h1>
                    <p class="text-muted mb-3">
                        <strong><%= cancha.nombre %></strong>
                        <% if (cancha.tipoCancha) { %>
                            - <%= cancha.tipoCancha.nombre %>
                        <% } %>
                    </p>

                    <%- include('../components/error-panel.ejs') %>

                    <form action="<%= formAction %>" method="post">
                        <div class="mb-3">
                            <label class="form-label" for="calificacion">Calificación</label>
                            <select class="form-select" name="calificacion" id="calificacion" required>
                                <option value="">Selecciona una puntuación</option>
                                <% for (let i = 1; i <= 5; i += 1) { %>
                                    <option value="<%= i %>" <%= Number(resena.calificacion) === i ? 'selected' : '' %>>
                                        <%= i %>
                                    </option>
                                <% } %>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="comentario">Comentario</label>
                            <textarea class="form-control" name="comentario" id="comentario" rows="4"><%= resena.comentario %></textarea>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Guardar reseña</button>
                            <a href="/reservas" class="btn btn-secondary">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('../components/footer.ejs') %>
