<%- include('../components/header.ejs') %>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Canchas</h1>
            <p class="text-muted mb-0">
                <% if (currentUser && currentUser.rol === 'admin') { %>
                    Administra las canchas disponibles en el sistema.
                <% } else { %>
                    Consulta las canchas registradas y su estado actual.
                <% } %>
            </p>
        </div>
        <% if (currentUser && currentUser.rol === 'admin') { %>
            <a href="/canchas/nueva" class="btn btn-primary">Nueva cancha</a>
        <% } %>
    </div>

    <%- include('../components/error-panel.ejs') %>

    <% if (typeof(success) !== "undefined" && success) { %>
        <div class="alert alert-success" role="alert">
            <%= success %>
        </div>
    <% } %>

    <div class="card">
        <div class="card-body p-0">
            <% if (!canchas.length) { %>
                <div class="p-4 text-center text-muted">
                    Todavia no hay canchas registradas.
                </div>
            <% } else { %>
                <div class="table-responsive">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Tipo</th>
                                <th>Precio por hora</th>
                                <th>Estado</th>
                                <% if (currentUser && currentUser.rol === 'admin') { %>
                                    <th class="text-end">Acciones</th>
                                <% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% canchas.forEach((cancha) => { %>
                                <tr>
                                    <td><%= cancha.nombre %></td>
                                    <td><%= cancha.tipoCancha ? cancha.tipoCancha.nombre : 'Sin tipo' %></td>
                                    <td>Bs. <%= Number(cancha.precioPorHora).toFixed(2) %></td>
                                    <td>
                                        <% if (cancha.estado === 'activa') { %>
                                            <span class="badge text-bg-success">Activa</span>
                                        <% } else { %>
                                            <span class="badge text-bg-secondary">Inactiva</span>
                                        <% } %>
                                    </td>
                                    <% if (currentUser && currentUser.rol === 'admin') { %>
                                        <td class="text-end">
                                            <a href="/canchas/<%= cancha.id %>/editar" class="btn btn-sm btn-outline-primary">Editar</a>
                                            <form action="/canchas/<%= cancha.id %>/eliminar" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                                            </form>
                                        </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../components/footer.ejs') %>
